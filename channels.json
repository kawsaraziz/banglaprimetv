এই কোডের ভিতর ভিডিও প্লেয়ার এর চ্যানেল চালুর আগে দেয়া এই ছবি প্লেয়ারে শো করবে এবং লোডিং বা বাফারিং এর সময়ও করবে শুধু মাত্র চ্যানেল এর ভিডিও কলে এটা হাইড হয়ে যাবে
চ্যানেল চলাকালীন মোবাইলের স্কিন বন্ধ হয়ে যাচ্ছে এটা সমাধান কর যেন চ্যানেল চলাকালীন স্কিন বন্ধ না হয় নীচে কোড দিচ্ছি আমি।
আমার দেয়া M3u8 কোড গুলো অপরিবর্তিত রেখে পিছনের থেকে 3 টা চ্যানেল কমিয়ে 1 এর আগে 3 টা ডামি চ্যানেল বসিয়ে দাও এবং সব আগের মতোই থাকবে এবং প্লেয়ার এর উপরে একটা চ্যানেল সার্চ ইঞ্জিন বসিয়ে দাও।প্লেয়ার এর ভিতর landscape mode এ ব্রাইটনেস ভলিউম কমানো বাড়ানো সিস্টেম mx player এর মত এবং চ্যানেল পরিবর্তনের জন্য বাটন বসিয়ে দাও।বাটন গুলো অটো হাইড এবং টাচ করলে শো করবে
আমি তোমাকে আমার আগের কোড দিচ্ছি এখানে আমি M3u8 লিংক এবং লোগো লিংক চ্যানেল name description 4টার দিয়েছি তুমি এগুলো রেখে আমাকে 150 চ্যানেল এর জন্য বানিয়ে দাও।আর হ্যা তুমি কিন্তু প্লেয়ার ল্যান্ডস্কেপ এবং prev next button দাও নি আবার স্ক্রলিং বিজ্ঞপ্তিও দাও নি এগোলো অ্যাড করে আমাকে বানিয়ে দাও <!DOCTYPE html> <html lang="bn" data-theme="dark"> <head>     <meta charset="UTF-8">     <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">     <title>কাওসার টিভি | Kawsar TV</title>          <!-- Google Fonts & FontAwesome Icons -->     <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=Orbitron:wght@500;700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">          <!-- Video.js Player CSS -->     <link href="https://vjs.zencdn.net/8.3.0/video-js.css" rel="stylesheet" />     <link href="https://unpkg.com/@videojs/themes@1.0.1/dist/city/index.css" rel="stylesheet">     <style>         :root {             --bg-gradient: linear-gradient(135deg, #06060c 0%, #111122 100%);             --glass-bg: rgba(22, 22, 39, 0.75);             --glass-border: rgba(255, 255, 255, 0.08);             --card-bg: rgba(255, 255, 255, 0.03);             --card-active: linear-gradient(90deg, rgba(255, 42, 116, 0.25) 0%, rgba(42, 157, 244, 0.1) 100%);             --accent-color: #ff2a74;             --secondary-accent: #2ab6ff;             --text-color: #ffffff;             --text-secondary: #94a3b8;             --marquee-bg: rgba(30, 30, 48, 0.8);             --neon-shadow: 0 0 15px rgba(255, 42, 116, 0.6);         }         [data-theme="light"] {             --bg-gradient: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);             --glass-bg: rgba(255, 255, 255, 0.85);             --glass-border: rgba(15, 23, 42, 0.1);             --card-bg: rgba(15, 23, 42, 0.03);             --card-active: linear-gradient(90deg, rgba(255, 42, 116, 0.15) 0%, rgba(42, 157, 244, 0.1) 100%);             --accent-color: #ff2a74;             --secondary-accent: #0284c7;             --text-color: #0f172a;             --text-secondary: #64748b;             --marquee-bg: rgba(255, 255, 255, 0.9);             --neon-shadow: 0 0 10px rgba(255, 42, 116, 0.3);         }         * {             box-sizing: border-box;             margin: 0;             padding: 0;             user-select: none;         }         body {             font-family: 'Hind Siliguri', 'Poppins', sans-serif;             background: var(--bg-gradient);             color: var(--text-color);             height: 100vh;             width: 100vw;             overflow: hidden;             display: flex;             justify-content: center;         }         .app-container {             display: flex;             width: 100%;             height: 100%;             max-width: 1600px;             position: relative;         }         /* বাম পাশের সাইডবার */         .sidebar {             width: 360px;             background: var(--glass-bg);             backdrop-filter: blur(16px);             -webkit-backdrop-filter: blur(16px);             border-right: 1px solid var(--glass-border);             display: flex;             flex-direction: column;             flex-shrink: 0;             z-index: 200;         }         .brand {             padding: 25px 20px;             text-align: center;             border-bottom: 1px solid var(--glass-border);             position: relative;         }         /* Kawsar TV নড়াচড়া ও শাইন অ্যানিমেশন */         .brand h1, .nav-logo h1 {             font-size: 28px;             font-weight: 700;             font-family: 'Poppins', sans-serif;             background: linear-gradient(to right, #ff2a74, #ff7e40, #2ab6ff, #ff2a74);             background-size: 300% auto;             -webkit-background-clip: text;             -webkit-text-fill-color: transparent;             animation: shineText 3s linear infinite, floatText 3s ease-in-out infinite;             display: inline-block;         }         @keyframes shineText {             0% { background-position: 0% center; }             100% { background-position: 300% center; }         }         @keyframes floatText {             0%, 100% { transform: translateY(0) scale(1); }             50% { transform: translateY(-4px) scale(1.03); }         }         .sidebar-close-btn {             display: none;             position: absolute;             right: 20px;             top: 25px;             font-size: 22px;             color: var(--text-color);             cursor: pointer;         }         .channel-section-title {             padding: 15px 20px 8px 20px;             font-size: 13px;             text-transform: uppercase;             color: var(--text-secondary);             font-weight: 700;             display: flex;             justify-content: space-between;             align-items: center;         }         .sidebar-list-container {             flex: 1;             overflow-y: auto;             padding: 5px 15px 15px 15px;         }         .sidebar-list-container::-webkit-scrollbar { width: 5px; }         .sidebar-list-container::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 10px; }         /* চ্যানেল আইটেম ডিজাইন */         .channel-item {             display: flex;             align-items: center;             padding: 14px;             margin-bottom: 12px;             background: var(--card-bg);             border: 1px solid var(--glass-border);             border-radius: 14px;             cursor: pointer;             transition: all 0.25s ease;         }         .channel-item:hover, .channel-item.active {             background: var(--card-active);             border-color: var(--accent-color);             box-shadow: var(--neon-shadow);         }         .channel-logo-img {             width: 46px;             height: 46px;             object-fit: cover;             border-radius: 10px;             margin-right: 15px;             background: #ffffff;         }         .channel-info {             flex: 1;             overflow: hidden;         }         .channel-info h4 {             font-size: 15px;             font-weight: 600;             margin-bottom: 3px;             white-space: nowrap;             overflow: hidden;             text-overflow: ellipsis;         }         .channel-info p {             font-size: 12px;             color: var(--text-secondary);             white-space: nowrap;             overflow: hidden;             text-overflow: ellipsis;         }         .play-icon-indicator {             color: var(--accent-color);             font-size: 16px;             opacity: 0;         }         .channel-item.active .play-icon-indicator {             opacity: 1;         }         .copyright-area {             padding: 15px;             text-align: center;             font-size: 12px;             color: var(--text-secondary);             border-top: 1px solid var(--glass-border);             background: rgba(0,0,0,0.15);         }         /* ডান পাশের মূল এরিয়া */         .main-content {             flex: 1;             display: flex;             flex-direction: column;             height: 100%;             overflow: hidden;         }         .navbar {             padding: 12px 30px;             display: flex;             justify-content: space-between;             align-items: center;             border-bottom: 1px solid var(--glass-border);             background: var(--glass-bg);             backdrop-filter: blur(10px);             -webkit-backdrop-filter: blur(10px);             z-index: 11;         }         .nav-left-box {             display: flex;             align-items: center;         }         .mobile-menu-btn {             font-size: 22px;             color: var(--text-color);             cursor: pointer;             margin-right: 15px;             display: none;         }         .nav-controls {             display: flex;             align-items: center;             gap: 20px;         }         .smart-clock-panel {             display: flex;             flex-direction: column;             align-items: flex-end;         }         .digital-time {             font-family: 'Orbitron', sans-serif;             font-size: 18px;             font-weight: 700;             color: var(--secondary-accent);         }         .digital-date {             font-size: 11px;             color: var(--text-secondary);         }         /* ডে-নাইট গোল বাটন */         .theme-toggle-btn {             background: rgba(255,255,255,0.08);             color: var(--text-color);             border: 1px solid var(--glass-border);             width: 42px;             height: 42px;             border-radius: 50%;             cursor: pointer;             font-size: 18px;             display: flex;             align-items: center;             justify-content: center;             transition: all 0.3s ease;         }         .theme-toggle-btn:hover {             transform: scale(1.1);             border-color: var(--accent-color);             color: var(--accent-color);         }         /* [STABLE ZONE] প্লেয়ার হিরো এরিয়া */         .player-fixed-hero-zone {             width: 100%;             max-width: 1100px;             margin: 0 auto;             padding: 20px 30px 10px 30px;             flex-shrink: 0;              z-index: 10;             position: relative;         }         /* প্লেয়ার রিল্যাটিভ কন্টেইনার */         .player-wrapper-outer {             position: relative;             width: 100%;         }         .player-container {             width: 100%;             border-radius: 20px 20px 0 0;             overflow: hidden;             box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);             background: #000000;             position: relative;             border: 1px solid var(--glass-border);             border-bottom: none;             aspect-ratio: 16 / 9;         }         /* প্লেয়ারের ঠিক নিচের নেভিগেশন প্যানেল (৫ সেকেন্ডে হাইড হবে) */         .player-navigation-bar {             width: 100%;             background: rgba(12, 12, 26, 0.95);             border: 1px solid var(--glass-border);             border-top: 1px solid rgba(255, 255, 255, 0.1);             border-radius: 0 0 20px 20px;             padding: 12px 20px;             display: flex;             justify-content: space-between;             align-items: center;             box-shadow: 0 15px 35px rgba(0,0,0,0.6);             transition: opacity 0.5s ease, visibility 0.5s ease;             opacity: 1;             visibility: visible;             z-index: 2000;         }         /* বাটন লুকিয়ে যাওয়ার স্টেট ক্লাস */         .player-navigation-bar.hide-controls {             opacity: 0;             visibility: hidden;         }         [data-theme="light"] .player-navigation-bar {             background: rgba(238, 242, 246, 0.95);         }         .nav-btn {             background: var(--accent-color);             color: #ffffff;             border: none;             padding: 10px 20px;             border-radius: 10px;             font-family: 'Hind Siliguri', sans-serif;             font-size: 14px;             font-weight: 700;             cursor: pointer;             display: flex;             align-items: center;             gap: 8px;             transition: all 0.2s ease;             box-shadow: 0 4px 12px rgba(255, 42, 116, 0.3);         }         .nav-btn:hover { background: #e01b5f; transform: translateY(-1px); }         .nav-btn:active { transform: translateY(1px); }         .nav-btn.prev-btn { background: #334155; box-shadow: 0 4px 12px rgba(51, 65, 85, 0.3); }         [data-theme="light"] .nav-btn.prev-btn { background: #64748b; }         .nav-btn.prev-btn:hover { background: #1e293b; }         /* ল্যান্ডস্কেপ ফুলস্ক্রিনে বাটন ধরে রাখার জন্য বিশেষ Video.js ওভাররাইড সিএসএস */         .video-js.vjs-fullscreen + .player-navigation-bar,         .video-js:fullscreen + .player-navigation-bar {             position: absolute !important;             bottom: 0 !important;             left: 0 !important;             width: 100% !important;             background: rgba(0, 0, 0, 0.85) !important;             border-radius: 0 !important;             border: none !important;             padding: 15px 40px !important;         }         .player-custom-poster {             position: absolute;             top: 0;             left: 0;             width: 100%;             height: 100%;             background-size: cover;             background-position: center;             background-image: url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1200&auto=format&fit=crop');              z-index: 5;             display: flex;             justify-content: center;             align-items: center;         }         .poster-overlay-content {             text-align: center;             background: rgba(0, 0, 0, 0.7);             padding: 20px 30px;             border-radius: 15px;             border: 1px solid rgba(255,255,255,0.1);         }         .fast-spinner {             width: 36px;             height: 36px;             border: 4px solid rgba(255, 42, 116, 0.2);             border-top: 4px solid var(--accent-color);             border-radius: 50%;             animation: spin 0.6s linear infinite;             margin: 12px auto;         }         @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }         .video-js { width: 100% !important; height: 100% !important; }         /* [SCROLLABLE ZONE] */         .content-scrollable-body {             flex: 1;             overflow-y: auto;             padding: 0 30px 30px 30px;         }         .content-scrollable-body::-webkit-scrollbar { width: 6px; }         .content-scrollable-body::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 10px; }         .scrollable-inner-wrapper {             width: 100%;             max-width: 1100px;             margin: 0 auto;         }         /* নোটিশ স্ক্রোলার */         .marquee-container {             width: 100%;             margin-top: 15px;             background: var(--marquee-bg);             border: 1px solid var(--glass-border);             border-radius: 14px;             padding: 12px;             display: flex;             align-items: center;             overflow: hidden;             position: relative;         }         .marquee-label {             background: var(--accent-color);             color: white;             padding: 4px 14px;             border-radius: 8px;             font-size: 13px;             font-weight: 700;             z-index: 5;         }         .marquee-box {             flex: 1;             overflow: hidden;             position: relative;             display: flex;             margin-left: 15px;         }         .marquee-text {             font-size: 14px;             font-weight: 600;             white-space: nowrap;             display: inline-block;             padding-left: 100%;             animation: kawsarMarquee 25s linear infinite;         }         @keyframes kawsarMarquee {             0%   { transform: translate3d(0, 0, 0); }             100% { transform: translate3d(-100%, 0, 0); }         }         /* বিবরণী কার্ড */         .stream-details {             width: 100%;             margin-top: 20px;             background: var(--glass-bg);             padding: 20px;             border-radius: 18px;             border: 1px solid var(--glass-border);         }         .live-badge {             background: var(--accent-color);             color: white;             padding: 4px 10px;             border-radius: 6px;             font-size: 11px;             font-weight: 700;             display: inline-block;             margin-bottom: 10px;         }         .stream-details h2 { font-size: 22px; margin-bottom: 6px; font-weight: 700; }         .stream-details p { color: var(--text-secondary); font-size: 14px; line-height: 1.5; }         /* সাজেস্টেড চ্যানেল লিস্ট গ্রিড */         .suggestion-section-heading {             padding: 25px 5px 12px 5px;             font-size: 15px;             font-weight: 700;             display: flex;             align-items: center;             gap: 8px;         }         .main-channel-grid {             display: grid;             grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));             gap: 15px;         }         /* মোবাইল রেসপন্সিভ */         .sidebar-overlay {             display: none;             position: fixed;             top: 0;             left: 0;             width: 100vw;             height: 100vh;             background: rgba(0,0,0,0.5);             backdrop-filter: blur(4px);             z-index: 150;         }         @media (max-width: 992px) {             .sidebar { position: fixed; left: -360px; top: 0; height: 100vh; width: 300px; z-index: 200; transition: left 0.3s ease; }             .sidebar.open { left: 0; }             .sidebar-close-btn { display: block; }             .mobile-menu-btn { display: block; }             .smart-clock-panel { display: none; }             .player-fixed-hero-zone { padding: 10px 15px 5px 15px; }             .player-container { border-radius: 12px 12px 0 0; }             .player-navigation-bar { border-radius: 0 0 12px 12px; padding: 8px 12px; }             .nav-btn { padding: 6px 12px; font-size: 13px; }             .content-scrollable-body { padding: 0 15px 20px 15px; }             .main-channel-grid { grid-template-columns: 1fr; }             .sidebar-overlay.show { display: block; }         }     </style> </head> <body>     <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>     <div class="app-container">                  <!-- বাম পাশের প্যানেল -->         <div class="sidebar" id="sidebarPanel">             <div class="brand">                 <h1>Kawsar TV</h1>                 <div class="sidebar-close-btn" onclick=